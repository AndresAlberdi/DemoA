rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper para verificar si el usuario es admin consultando Firestore
    function isAdmin() {
      return request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
    
    match /{path=**} {
      allow read, write: if isAdmin();
    }
    
    match /documentos_identidad/{fileName} {
      allow read, write: if request.auth != null; // Idealmente CI, pero request.auth no tiene el CI, así que permitimos lectura/escritura general condicionada.
    }
    match /titulos_bachiller/{fileName} {
      allow read, write: if request.auth != null; // En una app real, el CI debería estar en un custom claim o matchear el nombre.
    }
  }
}
